# ─────────────────────────────────────────────────────────────────────
# PRISM Environment Variables — All Tracks
# Copy to `.env` and fill in the values.
#
# Settlement vars (PRISM_HOOK_ADDRESS, PRIVATE_KEY, UNICHAIN_RPC_URL) can be
# left empty — the orchestrator then emits mock tx hashes via SHA-256
# (see crates/prism-orchestrator/src/main.rs:242-244). Useful for running
# real proving without deploying PrismHook on-chain yet.
# ─────────────────────────────────────────────────────────────────────

# ═══════ Dev 1: Rust Orchestrator ═══════

# WebSocket server bind address
WS_BIND_ADDR=0.0.0.0:8765

# Seconds between epoch ticks
EPOCH_DURATION_SECS=12

# Set to "false" to invoke the real SP1 SDK prover
USE_MOCK_PROVER=false

# SP1 prover backend: "network" (Succinct hosted) or "cpu" (local).
SP1_PROVER=network

# Succinct Network whitelisted private key. Required when SP1_PROVER=network.
SP1_PRIVATE_KEY=

# Uniswap REST API base URL (for real market data)
UNISWAP_API_URL=https://api.uniswap.org

# ═══════ Dev 1: Aave HF query (optional) ═══════
# When unset, AaveClient falls back to HealthFactor=2.0 (healthy).

AAVE_POOL_ADDRESS=
AAVE_RPC_URL=
AAVE_USER_ADDRESS=

# ═══════ Dev 1: On-chain Settlement ═══════
# Leave empty to use mock tx hashes (no on-chain settlement).

# Deployed PrismHook contract on Unichain Sepolia.
#   Real-verifier (production):  0x0B9Ae4690F8b6EAbB1511a6e1C64C948b9edCFC0
#   Mock-verifier (demo theater): 0xc64E1F5AB1B13B6E8D2E8e8e579E087c52054fC0
# Use the demo hook when USE_MOCK_PROVER=true so settleEpoch lands on-chain;
# the production hook will revert mock proofs by design. See LOCAL_DEMO.md.
PRISM_HOOK_ADDRESS=0x0B9Ae4690F8b6EAbB1511a6e1C64C948b9edCFC0



# Operator EOA private key (must have OPERATOR_ROLE if access control is added)
PRIVATE_KEY=0xd8dfd0f29eb7b26bf3171d3bbee542f6702310e821da825847177efdec256eb8

# Unichain Sepolia JSON-RPC endpoint
UNICHAIN_RPC_URL=https://sepolia.unichain.org

# ═══════ Dev 2: Foundry / Contracts ═══════

# Deployer private key for forge scripts
DEPLOYER_PRIVATE_KEY=0xd8dfd0f29eb7b26bf3171d3bbee542f6702310e821da825847177efdec256eb8

# Pre-deployed SP1VerifierGateway address. Leave empty + USE_MOCK_VERIFIER=true
# to deploy a fresh MockSP1Verifier locally.
SP1_GATEWAY_ADDRESS=0xec95e0b24a0475b9afcafd609b4d51d001380e75
USE_MOCK_VERIFIER=false

# Uniswap V4 PoolManager on Unichain Sepolia
POOL_MANAGER=0x00b036b58a818b1bc34d502d3fe730db729e62ac

# SP1 Aggregator verification key (from `cargo prove build` + extract_aggregator_vkey)
AGGREGATOR_VKEY=0x00bfb7e054593ffe30bb29c986846bb01ad352b90f3a0fe15a7e0152efcff512

# ═══════ Dev 3: Agent Private Keys ═══════
# (Store in .env.agents — see AGENT_WALLETS.md)

AGENT_ALPHA_KEY=0xf2E96F75a19443c17E88f2cd8e85a188A37D1EFF
AGENT_BETA_KEY=0x9E8C1Bc1D077Cb1aBb60FAa3CB80491e217FBC59
AGENT_GAMMA_KEY=0xd01F4f010DcB7C878B807B0273A8e3bAA1D1f22D
AGENT_DELTA_KEY=0x0bfF21FB77Fc98068b02B9821Cc2E8306c55F459
AGENT_EPSILON_KEY=0x932aE7e2CA55Ff664699fD4936Ae61AeC487BAB5
